# Footprints Hub Store local environment template.
# Copy to .env for local-only development. Do not commit real secrets.

APP_ENV=local
APP_URL=http://localhost

MAGENTO_BACKEND_FRONTNAME=admin
MAGENTO_BASE_URL=http://footprintshub.test/

MAGENTO_DB_HOST=localhost
MAGENTO_DB_NAME=footprintshub_magento
MAGENTO_DB_USER=footprintshub
MAGENTO_DB_PASSWORD=change_me

MAGENTO_ADMIN_FIRSTNAME=David
MAGENTO_ADMIN_LASTNAME=Kam
MAGENTO_ADMIN_EMAIL=admin@example.com
MAGENTO_ADMIN_USER=admin
MAGENTO_ADMIN_PASSWORD=change_me

MAGENTO_SEARCH_ENGINE=opensearch
MAGENTO_OPENSEARCH_HOST=localhost
MAGENTO_OPENSEARCH_PORT=9200

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

HERO_STUDIO_URL=http://localhost:3000
HERO_STUDIO_WEBHOOK_SECRET=change-me
