generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShopStatus {
  draft
  active
  suspended
}

enum DomainType {
  system_subdomain
  custom_domain
  root_domain
}

enum DomainStatus {
  pending
  active
  failed
}

enum ProductType {
  physical
  digital
  bundle
  membership
  preorder
  blind_box
  booster_pack
  digital_unlock
  service
  donation_like_supporter_bundle
}

enum Franchise {
  footprints
  matrix_decoded
  hero_studio
  battery_movement
  other
}

enum ProductStatus {
  draft
  active
  archived
  hidden
  sold_out
}

enum OrderStatus {
  pending
  awaiting_payment
  paid
  processing
  fulfilled
  partially_fulfilled
  cancelled
  refunded
  partially_refunded
  failed
}

enum DiscountType {
  percent
  fixed
  free_shipping
}

enum UserRole {
  platform_owner
  shop_owner
  creator_admin
  staff
  support
  customer
}

enum ProductVisibility {
  visible
  hidden
  catalog_only
  direct_link
}

enum RelatedProductType {
  related
  upsell
  cross_sell
}

enum CartStatus {
  active
  converted
  expired
  abandoned
}

enum DiscountRuleScope {
  cart
  catalog
  affiliate_coupon
}

enum OrderAddressType {
  shipping
  billing
}

enum PaymentProvider {
  stripe
  manual
  battery_coin
}

enum PaymentStatus {
  unpaid
  requires_action
  paid
  failed
  refunded
  partially_refunded
}

enum FulfillmentStatus {
  unfulfilled
  partially_fulfilled
  fulfilled
  digital_fulfilled
  not_required
}

enum RefundStatus {
  requested
  approved
  processing
  succeeded
  failed
  cancelled
}

enum ShipmentStatus {
  pending
  processing
  shipped
  delivered
  cancelled
}

enum InventoryLedgerType {
  initial_adjustment
  reservation
  release
  deduction
  restock
  refund_adjustment
  manual_adjustment
}

enum ShippingMethodType {
  flat_rate
  free_shipping
  local_pickup
  digital_only
}

enum WebhookEventStatus {
  received
  processing
  processed
  failed
  ignored
}

enum AffiliateProgramStatus {
  active
  inactive
}

enum AttributionModel {
  first_touch
  last_touch
  coupon_priority
  lifetime
  manual_override
}

enum AffiliateStatus {
  pending
  approved
  rejected
  suspended
}

enum AffiliateAttributionType {
  first_touch
  last_touch
  coupon
  lifetime
  manual
}

enum CommissionType {
  percentage
  fixed
  percentage_plus_fixed
  store_credit
}

enum CommissionBase {
  order_subtotal
  product_subtotal
  item_subtotal
  direct_commission
  gross_margin
}

enum CommissionScope {
  global
  product
  category
  collection
  creator_shop
  affiliate
  affiliate_product
  affiliate_category
  campaign
  membership
  rank
  performance_tier
  coupon
  lifetime
  manual
}

enum AffiliatePlanStatus {
  draft
  active
  archived
}

enum AffiliatePlanType {
  flat
  product
  category
  campaign
  creator_shop
  rank_based
  performance_tier
  seven_level
  lifetime
  coupon
  hybrid
}

enum AffiliateBusinessModelType {
  flat
  product
  category
  campaign
  creator_shop
  rank_based
  performance_tier
  seven_level
  lifetime
  coupon
  hybrid
  manual
}

enum AffiliateCompressionBehavior {
  pay_zero
  skip_ineligible
  compress_to_next_qualified
}

enum AffiliatePerformanceMetric {
  monthly_sales
  monthly_orders
  lifetime_sales
  approved_commissions
}

enum LifetimeAttributionStatus {
  active
  expired
  revoked
}

enum AffiliateCommissionType {
  direct
  multi_level
  signup
  performance
  click
  share
  manual
  rank
  coupon
}

enum AffiliateCommissionStatus {
  pending
  held
  approved
  rejected
  paid
  reversed
  partially_reversed
  capped
}

enum AffiliateWalletLedgerType {
  pending_credit
  approve_credit
  reject_debit
  payout_debit
  reversal_debit
  manual_credit
  manual_debit
  coupon_debit
}

enum AffiliateWalletBalanceType {
  pending
  approved
  available
  paid
  rejected
}

enum AffiliatePayoutMethod {
  manual_bank
  paypal
  paypal_placeholder
  stripe_connect
  stripe_connect_placeholder
  store_credit
}

enum AffiliatePayoutStatus {
  requested
  approved
  processing
  paid
  rejected
  cancelled
}

enum AffiliateRankRequirementType {
  signup
  direct_referrals
  total_sales
  organization_affiliates
  reach_rank
  manual
}

enum AffiliateBonusType {
  signup
  performance
  click
  share
  rank
  manual
}

enum AffiliateBonusLimitType {
  none
  daily
  weekly
  monthly
  lifetime
}

enum AffiliateCouponType {
  referral_discount
  wallet_credit
}

enum AffiliateCouponDiscountType {
  percent
  fixed
}

enum MarketingAssetType {
  banner
  product_banner
  social_image
  html_embed
  qr
}

model Shop {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  subdomain    String?      @unique
  customDomain String?      @unique
  description  String?
  logoUrl      String?
  bannerUrl    String?
  ownerUserId  String?
  status       ShopStatus   @default(draft)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  owner          User?        @relation("ShopOwner", fields: [ownerUserId], references: [id])
  domains        ShopDomain[]
  products       Product[]
  categories     Category[]
  collections    Collection[]
  carts          Cart[]
  orders         Order[]
  discounts      DiscountCode[]
  discountRules  DiscountRule[]
  taxClasses     TaxClass[]
  shippingMethods ShippingMethod[]
  shopSettings   ShopSetting[]
  inventoryLedgers InventoryLedger[]
  adminAuditLogs AdminAuditLog[]
  webhookEvents  WebhookEvent[]
  customers      Customer[]
  digitalUnlocks DigitalUnlock[]
  creatorPayouts CreatorPayout[]
  affiliatePrograms AffiliateProgram[]
  affiliatePlans    AffiliatePlan[]
  affiliatePlanLevels AffiliatePlanLevel[]
  affiliatePerformanceTiers AffiliatePerformanceTier[]
  affiliateQualificationSnapshots AffiliateQualificationSnapshot[]
  lifetimeCustomerAttributions LifetimeCustomerAttribution[]
  affiliates        Affiliate[]
  affiliateTreeClosures AffiliateTreeClosure[]
  affiliateClicks   AffiliateClick[]
  affiliateAttributions AffiliateAttribution[]
  commissionRules   CommissionRule[]
  multiLevelCommissionRules MultiLevelCommissionRule[]
  affiliateCommissions AffiliateCommission[]
  affiliateWalletLedgers AffiliateWalletLedger[]
  affiliatePayouts AffiliatePayout[]
  affiliateRanks AffiliateRank[]
  affiliateBonusRules AffiliateBonusRule[]
  affiliateCoupons AffiliateCoupon[]
  marketingAssets MarketingAsset[]
  affiliateNotifications AffiliateNotification[]
  affiliateAuditLogs AffiliateAuditLog[]

  @@index([ownerUserId])
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  role             UserRole @default(customer)
  heroStudioUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ownedShops Shop[] @relation("ShopOwner")
  customers  Customer[]
  adminAuditLogs AdminAuditLog[]

  @@index([role])
  @@index([heroStudioUserId])
}

model ShopDomain {
  id        String       @id @default(cuid())
  shopId    String
  hostname  String       @unique
  type      DomainType
  status    DomainStatus @default(pending)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Product {
  id                     String        @id @default(cuid())
  shopId                 String
  taxClassId             String?
  title                  String
  slug                   String
  subtitle               String?
  description            String
  shortDescription       String?
  productType            ProductType
  franchise              Franchise
  status                 ProductStatus @default(draft)
  visibility             ProductVisibility @default(visible)
  priceCents             Int
  compareAtPriceCents    Int?
  currency               String        @default("USD")
  sku                    String?
  inventoryQuantity      Int           @default(0)
  trackInventory         Boolean       @default(true)
  allowBackorder         Boolean       @default(false)
  lowStockThreshold      Int?
  imageUrl               String?
  galleryUrls            String[]      @default([])
  seoTitle               String?
  seoDescription         String?
  metaKeywords           String[]      @default([])
  isFeatured             Boolean       @default(false)
  isLimitedEdition       Boolean       @default(false)
  preorderStatus         String?
  preorderReleaseAt      DateTime?
  requiresShipping       Boolean       @default(true)
  digitalUnlockIncluded  Boolean       @default(false)
  tokenGated             Boolean       @default(false)
  tokenGateRule          Json?
  isRandomized           Boolean       @default(false)
  oddsDisclosureUrl      String?
  metadata               Json?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  shop       Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  taxClass   TaxClass?        @relation(fields: [taxClassId], references: [id])
  variants   ProductVariant[]
  media      ProductMedia[]
  productCategories ProductCategory[]
  productCollections ProductCollection[]
  relatedProducts RelatedProduct[] @relation("ProductRelatedSource")
  relatedTo RelatedProduct[] @relation("ProductRelatedTarget")
  cartItems  CartItem[]
  orderItems OrderItem[]
  unlocks    DigitalUnlock[]
  affiliateClicks AffiliateClick[]
  commissionRules CommissionRule[]
  affiliateCoupons AffiliateCoupon[]
  inventoryLedgers InventoryLedger[]

  @@unique([shopId, slug])
  @@index([shopId])
  @@index([franchise])
  @@index([productType])
  @@index([status, visibility])
  @@index([taxClassId])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  title             String
  sku               String?
  priceCents        Int?
  inventoryQuantity Int      @default(0)
  trackInventory    Boolean  @default(true)
  allowBackorder    Boolean  @default(false)
  lowStockThreshold Int?
  attributes        Json?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]
  inventoryLedgers InventoryLedger[]

  @@index([productId])
  @@index([sku])
}

model ProductMedia {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  mediaType String   @default("image")
  sortOrder Int      @default(0)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Category {
  id             String   @id @default(cuid())
  shopId         String
  parentId       String?
  name           String
  slug           String
  description    String?
  imageUrl       String?
  seoTitle       String?
  seoDescription String?
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  parent Category? @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")
  products ProductCategory[]

  @@unique([shopId, slug])
  @@index([shopId, parentId])
}

model ProductCategory {
  productId  String
  categoryId String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId, sortOrder])
}

model Collection {
  id             String   @id @default(cuid())
  shopId         String
  name           String
  slug           String
  description    String?
  imageUrl       String?
  seoTitle       String?
  seoDescription String?
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products ProductCollection[]

  @@unique([shopId, slug])
  @@index([shopId, active])
}

model ProductCollection {
  productId    String
  collectionId String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId, sortOrder])
}

model RelatedProduct {
  id               String             @id @default(cuid())
  shopId           String
  sourceProductId  String
  relatedProductId String
  type             RelatedProductType @default(related)
  sortOrder        Int                @default(0)
  createdAt        DateTime           @default(now())

  sourceProduct Product @relation("ProductRelatedSource", fields: [sourceProductId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("ProductRelatedTarget", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, relatedProductId, type])
  @@index([shopId, sourceProductId, type])
}

model Cart {
  id         String   @id @default(cuid())
  shopId     String
  customerId String?
  appliedDiscountCodeId String?
  sessionId  String
  currency   String   @default("USD")
  status     CartStatus @default(active)
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop     Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer?  @relation(fields: [customerId], references: [id])
  discountCode DiscountCode? @relation(fields: [appliedDiscountCodeId], references: [id])
  items    CartItem[]

  @@index([shopId])
  @@index([sessionId])
  @@index([status, expiresAt])
}

model CartItem {
  id             String   @id @default(cuid())
  cartId         String
  productId      String
  variantId      String?
  quantity       Int
  unitPriceCents Int
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([cartId])
  @@index([productId])
}

model Order {
  id                      String   @id @default(cuid())
  shopId                  String
  customerId              String?
  cartId                  String?
  affiliateAttributionId  String?
  orderNumber             String   @unique
  status                  OrderStatus @default(pending)
  paymentStatus           PaymentStatus @default(unpaid)
  fulfillmentStatus       FulfillmentStatus @default(unfulfilled)
  subtotalCents           Int
  discountCents           Int      @default(0)
  taxCents                Int      @default(0)
  shippingCents           Int      @default(0)
  totalCents              Int
  currency                String   @default("USD")
  stripeCheckoutSessionId String?  @unique
  stripePaymentIntentId   String?
  customerEmail           String?
  shippingAddress         Json?
  billingAddress          Json?
  adminNotes              String?
  termsAcceptedAt         DateTime?
  metadata                Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  shop     Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  addresses OrderAddress[]
  payments Payment[]
  refunds Refund[]
  shipments Shipment[]
  unlocks  DigitalUnlock[]
  payouts  CreatorPayout[]
  affiliateClicks AffiliateClick[]
  affiliateCommissions AffiliateCommission[]
  lifetimeCustomerAttributions LifetimeCustomerAttribution[]
  inventoryLedgers InventoryLedger[]
  webhookEvents WebhookEvent[]

  @@index([shopId])
  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  productId      String
  variantId      String?
  titleSnapshot  String
  skuSnapshot    String?
  quantity       Int
  unitPriceCents Int
  discountCents  Int      @default(0)
  taxCents       Int      @default(0)
  totalCents     Int
  metadata       Json?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  unlocks DigitalUnlock[]
  affiliateCommissions AffiliateCommission[]
  refundItems Refund[]
  shipmentItems ShipmentItem[]
  inventoryLedgers InventoryLedger[]

  @@index([orderId])
  @@index([productId])
}

model OrderAddress {
  id          String           @id @default(cuid())
  orderId     String
  type        OrderAddressType
  name        String?
  company     String?
  line1       String
  line2       String?
  city        String
  region      String?
  postalCode  String
  country     String
  phone       String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, type])
}

model Payment {
  id                    String          @id @default(cuid())
  shopId                String
  orderId               String
  provider              PaymentProvider @default(stripe)
  status                PaymentStatus   @default(unpaid)
  amountCents           Int
  currency              String          @default("USD")
  stripeCheckoutSessionId String?
  stripePaymentIntentId String?
  idempotencyKey        String?         @unique
  metadata              Json?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([orderId])
}

model Refund {
  id              String       @id @default(cuid())
  shopId          String
  orderId         String
  orderItemId     String?
  paymentId       String?
  status          RefundStatus @default(requested)
  amountCents     Int
  reason          String?
  stripeRefundId  String?
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])

  @@index([shopId, status])
  @@index([orderId])
}

model Shipment {
  id             String         @id @default(cuid())
  shopId         String
  orderId        String
  status         ShipmentStatus @default(pending)
  carrier        String?
  service        String?
  trackingNumber String?
  trackingUrl    String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items ShipmentItem[]

  @@index([shopId, status])
  @@index([orderId])
}

model ShipmentItem {
  id          String   @id @default(cuid())
  shipmentId  String
  orderItemId String
  quantity    Int
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@unique([shipmentId, orderItemId])
}

model Customer {
  id        String   @id @default(cuid())
  shopId    String
  userId    String?
  email     String
  name      String?
  phone     String?
  customerGroup String?
  tags      String[] @default([])
  heroStudioUserId String?
  verifiedFanId String?
  privacyMetadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop    Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user    User? @relation(fields: [userId], references: [id])
  addresses CustomerAddress[]
  carts   Cart[]
  orders  Order[]
  unlocks DigitalUnlock[]
  affiliates Affiliate[]
  lifetimeCustomerAttributions LifetimeCustomerAttribution[]

  @@unique([shopId, email])
  @@index([userId])
  @@index([heroStudioUserId])
}

model CustomerAddress {
  id          String   @id @default(cuid())
  customerId  String
  label       String?
  name        String?
  company     String?
  line1       String
  line2       String?
  city        String
  region      String?
  postalCode  String
  country     String
  phone       String?
  isDefaultShipping Boolean @default(false)
  isDefaultBilling  Boolean @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model AffiliateProgram {
  id                       String                 @id @default(cuid())
  shopId                   String
  name                     String
  status                   AffiliateProgramStatus @default(active)
  attributionModel         AttributionModel       @default(last_touch)
  cookieDays               Int                    @default(30)
  allowMultiLevel          Boolean                @default(true)
  maxLevels                Int                    @default(7)
  maxCommissionPoolBps     Int                    @default(2000)
  defaultCommissionType    CommissionType         @default(percentage)
  defaultCommissionValue   Int                    @default(1000)
  commissionBase           CommissionBase         @default(product_subtotal)
  autoApproveCommissions   Boolean                @default(false)
  autoApproveOrderStatuses String[]               @default([])
  holdDays                 Int                    @default(30)
  blockOwnReferrals        Boolean                @default(true)
  blockSaleItems           Boolean                @default(false)
  minPayoutCents           Int                    @default(5000)
  maxPayoutCents           Int?
  withdrawalFeeCents       Int                    @default(0)
  allowCouponGeneration    Boolean                @default(false)
  minCouponGenerationCents Int                    @default(2500)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  commissionRules CommissionRule[]
  multiLevelCommissionRules MultiLevelCommissionRule[]
  plans AffiliatePlan[]

  @@index([shopId])
}

model AffiliatePlan {
  id                         String              @id @default(cuid())
  shopId                     String
  affiliateProgramId         String?
  name                       String
  description                String?
  status                     AffiliatePlanStatus @default(draft)
  planType                   AffiliatePlanType
  isDefault                  Boolean             @default(false)
  currency                   String              @default("USD")
  maxActiveLevels            Int                 @default(7)
  maxCommissionPoolBps       Int?
  maxCommissionPoolCents     Int?
  allowLifetimeAttribution   Boolean             @default(false)
  lifetimeAttributionDays    Int?
  attributionModel           AttributionModel    @default(last_touch)
  cookieDays                 Int                 @default(30)
  holdDays                   Int                 @default(14)
  autoApproveCommissions     Boolean             @default(false)
  blockOwnReferrals          Boolean             @default(true)
  blockSaleItems             Boolean             @default(false)
  allowStoreCreditPayout     Boolean             @default(true)
  allowCashPayout            Boolean             @default(false)
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliateProgram AffiliateProgram? @relation(fields: [affiliateProgramId], references: [id])
  levels AffiliatePlanLevel[]
  performanceTiers AffiliatePerformanceTier[]
  commissionRules CommissionRule[]
  affiliates Affiliate[]
  commissions AffiliateCommission[]

  @@index([shopId, status])
  @@index([affiliateProgramId])
}

model AffiliatePlanLevel {
  id                    String                      @id @default(cuid())
  shopId                String
  affiliatePlanId       String
  levelDepth            Int
  label                 String
  enabled               Boolean                     @default(true)
  commissionType        CommissionType
  percentageBps         Int?
  fixedCents            Int?
  commissionBase        CommissionBase              @default(product_subtotal)
  maxPerOrderCents      Int?
  maxPerMonthCents      Int?
  requiresRankId        String?
  compressionBehavior   AffiliateCompressionBehavior @default(pay_zero)
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
