  createdAt     DateTime @default(now())

  fulfillment Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id])

  @@unique([fulfillmentId, orderItemId])
  @@index([orderItemId])
}

model Promotion {
  id         String          @id @default(cuid())
  shopId     String
  code       String?
  name       String
  type       PromotionType   @default(coupon)
  status     PromotionStatus @default(draft)
  startsAt   DateTime?
  endsAt     DateTime?
  usageLimit Int?
  usageCount Int             @default(0)
  metadata   Json?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  shop    Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  rules   PromotionRule[]
  actions PromotionAction[]

  @@unique([shopId, code])
  @@index([shopId, status])
  @@index([startsAt, endsAt])
}

model PromotionRule {
  id          String   @id @default(cuid())
  promotionId String
  attribute   String
  operator    String
  value       Json
  createdAt   DateTime @default(now())

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
}

model PromotionAction {
  id          String              @id @default(cuid())
  promotionId String
  type        PromotionActionType
  value       Json
  createdAt   DateTime            @default(now())

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
}

model CommerceEvent {
  id             String              @id @default(cuid())
  shopId         String?
  orderId        String?
  type           String
  aggregateType  String
  aggregateId    String
  payload        Json
  status         CommerceEventStatus @default(pending)
  idempotencyKey String?
  createdAt      DateTime            @default(now())
  processedAt    DateTime?

  shop  Shop?  @relation(fields: [shopId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@unique([idempotencyKey])
  @@index([shopId, status])
  @@index([orderId])
  @@index([type])
  @@index([aggregateType, aggregateId])
}

model IdempotencyKey {
  id          String               @id @default(cuid())
  key         String
  scope       String
  requestHash String?
  response    Json?
  status      IdempotencyKeyStatus @default(processing)
  createdAt   DateTime             @default(now())
  expiresAt   DateTime?

  @@unique([scope, key])
  @@index([status, expiresAt])
}

model ShopSetting {
  id        String   @id @default(cuid())
  shopId    String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, key])
}

model AdminRole {
  id          String   @id @default(cuid())
  shopId      String?
  name        String
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop  Shop?           @relation(fields: [shopId], references: [id])
  users AdminUserRole[]

  @@unique([shopId, name])
  @@index([shopId])
}

model AdminUserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  shopId    String?
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  shop Shop?     @relation(fields: [shopId], references: [id])

  @@unique([userId, roleId, shopId])
  @@index([shopId])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  shopId      String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  ipHash      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  shop  Shop? @relation(fields: [shopId], references: [id])
  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([shopId, entityType, entityId])
  @@index([actorUserId])
}

model WebhookEvent {
  id          String             @id @default(cuid())
  shopId      String?
  orderId     String?
  provider    String
  eventId     String
  eventType   String
  status      WebhookEventStatus @default(received)
  payloadHash String?
  processedAt DateTime?
  error       String?
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  shop  Shop?  @relation(fields: [shopId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@unique([provider, eventId])
  @@index([shopId, status])
}

model DigitalUnlock {
  id          String    @id @default(cuid())
  shopId      String
  orderId     String
  orderItemId String
  customerId  String
  productId   String
  unlockType  String
  unlockCode  String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  redeemedAt  DateTime?

  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@index([shopId])
  @@index([customerId])
  @@index([unlockCode])
}

model CreatorPayout {
  id            String    @id @default(cuid())
  shopId        String
  orderId       String
  creatorUserId String
  amountCents   Int
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  paidAt        DateTime?

  shop  Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([creatorUserId])
}
