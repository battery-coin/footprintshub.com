generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShopStatus {
  draft
  active
  suspended
}

enum DomainType {
  system_subdomain
  custom_domain
  root_domain
}

enum DomainStatus {
  pending
  active
  failed
}

enum ProductType {
  physical
  digital
  bundle
  membership
  preorder
  blind_box
  booster_pack
}

enum Franchise {
  footprints
  matrix_decoded
  hero_studio
  battery_movement
  other
}

enum ProductStatus {
  draft
  active
  archived
}

enum OrderStatus {
  pending
  paid
  fulfilled
  cancelled
  refunded
}

enum DiscountType {
  percent
  fixed
}

enum AffiliateProgramStatus {
  active
  inactive
}

enum AttributionModel {
  first_touch
  last_touch
  coupon_priority
  manual_override
}

enum AffiliateStatus {
  pending
  approved
  rejected
  suspended
}

enum AffiliateAttributionType {
  first_touch
  last_touch
  coupon
  manual
}

enum CommissionType {
  percentage
  fixed
  percentage_plus_fixed
}

enum CommissionBase {
  order_subtotal
  product_subtotal
  direct_commission
}

enum CommissionScope {
  global
  product
  category
  collection
  affiliate
  affiliate_product
  affiliate_category
  campaign
  membership
}

enum AffiliateCommissionType {
  direct
  multi_level
  signup
  performance
  click
  share
  manual
  rank
  coupon
}

enum AffiliateCommissionStatus {
  pending
  approved
  rejected
  paid
  reversed
  capped
}

enum AffiliateWalletLedgerType {
  pending_credit
  approve_credit
  reject_debit
  payout_debit
  reversal_debit
  manual_credit
  manual_debit
  coupon_debit
}

enum AffiliateWalletBalanceType {
  pending
  approved
  available
  paid
  rejected
}

enum AffiliatePayoutMethod {
  manual_bank
  paypal
  stripe_connect
  store_credit
}

enum AffiliatePayoutStatus {
  requested
  approved
  processing
  paid
  rejected
  cancelled
}

enum AffiliateRankRequirementType {
  signup
  direct_referrals
  total_sales
  organization_affiliates
  reach_rank
  manual
}

enum AffiliateBonusType {
  signup
  performance
  click
  share
  rank
  manual
}

enum AffiliateBonusLimitType {
  none
  daily
  weekly
  monthly
  lifetime
}

enum AffiliateCouponType {
  referral_discount
  wallet_credit
}

enum AffiliateCouponDiscountType {
  percent
  fixed
}

enum MarketingAssetType {
  banner
  product_banner
  social_image
  html_embed
  qr
}

model Shop {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  subdomain    String?      @unique
  customDomain String?      @unique
  description  String?
  logoUrl      String?
  bannerUrl    String?
  ownerUserId  String?
  status       ShopStatus   @default(draft)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  domains        ShopDomain[]
  products       Product[]
  carts          Cart[]
  orders         Order[]
  discounts      DiscountCode[]
  digitalUnlocks DigitalUnlock[]
  creatorPayouts CreatorPayout[]
  affiliatePrograms AffiliateProgram[]
  affiliates        Affiliate[]
  affiliateTreeClosures AffiliateTreeClosure[]
  affiliateClicks   AffiliateClick[]
  affiliateAttributions AffiliateAttribution[]
  commissionRules   CommissionRule[]
  multiLevelCommissionRules MultiLevelCommissionRule[]
  affiliateCommissions AffiliateCommission[]
  affiliateWalletLedgers AffiliateWalletLedger[]
  affiliatePayouts AffiliatePayout[]
  affiliateRanks AffiliateRank[]
  affiliateBonusRules AffiliateBonusRule[]
  affiliateCoupons AffiliateCoupon[]
  marketingAssets MarketingAsset[]
  affiliateNotifications AffiliateNotification[]
  affiliateAuditLogs AffiliateAuditLog[]
}

model ShopDomain {
  id        String       @id @default(cuid())
  shopId    String
  hostname  String       @unique
  type      DomainType
  status    DomainStatus @default(pending)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Product {
  id                     String        @id @default(cuid())
  shopId                 String
  title                  String
  slug                   String
  subtitle               String?
  description            String
  shortDescription       String?
  productType            ProductType
  franchise              Franchise
  status                 ProductStatus @default(draft)
  priceCents             Int
  compareAtPriceCents    Int?
  currency               String        @default("USD")
  sku                    String?
  inventoryQuantity      Int           @default(0)
  trackInventory         Boolean       @default(true)
  imageUrl               String?
  galleryUrls            String[]      @default([])
  isFeatured             Boolean       @default(false)
  isLimitedEdition       Boolean       @default(false)
  preorderStatus         String?
  digitalUnlockIncluded  Boolean       @default(false)
  tokenGated             Boolean       @default(false)
  metadata               Json?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  shop       Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  variants   ProductVariant[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  unlocks    DigitalUnlock[]
  affiliateClicks AffiliateClick[]
  commissionRules CommissionRule[]
  affiliateCoupons AffiliateCoupon[]

  @@unique([shopId, slug])
  @@index([shopId])
  @@index([franchise])
  @@index([productType])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  title             String
  sku               String?
  priceCents        Int?
  inventoryQuantity Int      @default(0)
  attributes        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
}

model Cart {
  id         String   @id @default(cuid())
  shopId     String
  customerId String?
  sessionId  String
  currency   String   @default("USD")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop     Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer?  @relation(fields: [customerId], references: [id])
  items    CartItem[]

  @@index([shopId])
  @@index([sessionId])
}

model CartItem {
  id             String   @id @default(cuid())
  cartId         String
  productId      String
  variantId      String?
  quantity       Int
  unitPriceCents Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([cartId])
  @@index([productId])
}

model Order {
  id                      String   @id @default(cuid())
  shopId                  String
  customerId              String?
  orderNumber             String   @unique
  status                  OrderStatus @default(pending)
  paymentStatus           String   @default("pending")
  fulfillmentStatus       String   @default("unfulfilled")
  subtotalCents           Int
  discountCents           Int      @default(0)
  taxCents                Int      @default(0)
  shippingCents           Int      @default(0)
  totalCents              Int
  currency                String   @default("USD")
  stripeCheckoutSessionId String?  @unique
  stripePaymentIntentId   String?
  customerEmail           String?
  shippingAddress         Json?
  billingAddress          Json?
  metadata                Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  shop     Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  unlocks  DigitalUnlock[]
  payouts  CreatorPayout[]
  affiliateClicks AffiliateClick[]
  affiliateCommissions AffiliateCommission[]

  @@index([shopId])
  @@index([customerId])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  productId      String
  variantId      String?
  titleSnapshot  String
  skuSnapshot    String?
  quantity       Int
  unitPriceCents Int
  totalCents     Int
  metadata       Json?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  unlocks DigitalUnlock[]
  affiliateCommissions AffiliateCommission[]

  @@index([orderId])
  @@index([productId])
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carts   Cart[]
  orders  Order[]
  unlocks DigitalUnlock[]
  affiliates Affiliate[]
}

model AffiliateProgram {
  id                       String                 @id @default(cuid())
  shopId                   String
  name                     String
  status                   AffiliateProgramStatus @default(active)
  attributionModel         AttributionModel       @default(last_touch)
  cookieDays               Int                    @default(30)
  allowMultiLevel          Boolean                @default(true)
  maxLevels                Int                    @default(7)
  maxCommissionPoolBps     Int                    @default(2000)
  defaultCommissionType    CommissionType         @default(percentage)
  defaultCommissionValue   Int                    @default(1000)
  commissionBase           CommissionBase         @default(product_subtotal)
  autoApproveCommissions   Boolean                @default(false)
  autoApproveOrderStatuses String[]               @default([])
  holdDays                 Int                    @default(30)
  blockOwnReferrals        Boolean                @default(true)
  blockSaleItems           Boolean                @default(false)
  minPayoutCents           Int                    @default(5000)
  maxPayoutCents           Int?
  withdrawalFeeCents       Int                    @default(0)
  allowCouponGeneration    Boolean                @default(false)
  minCouponGenerationCents Int                    @default(2500)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  commissionRules CommissionRule[]
  multiLevelCommissionRules MultiLevelCommissionRule[]

  @@index([shopId])
}

model Affiliate {
  id                       String          @id @default(cuid())
  shopId                   String
  userId                   String?
  customerId               String?
  email                    String
  name                     String
  phone                    String?
  referralCode             String
  status                   AffiliateStatus @default(pending)
  parentAffiliateId        String?
  rankId                   String?
  levelId                  String?
  approvedAt               DateTime?
  rejectedAt               DateTime?
  suspendedAt              DateTime?
  payoutMethod             String?
  payoutDetailsEncrypted   String?
  termsAcceptedAt          DateTime?
  disclosureAcceptedAt     DateTime?
  notes                    String?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])
  parent Affiliate? @relation("AffiliateParent", fields: [parentAffiliateId], references: [id])
  children Affiliate[] @relation("AffiliateParent")
  rank AffiliateRank? @relation(fields: [rankId], references: [id])
  ancestorClosures AffiliateTreeClosure[] @relation("AffiliateTreeAncestor")
  descendantClosures AffiliateTreeClosure[] @relation("AffiliateTreeDescendant")
  clicks AffiliateClick[]
  attributions AffiliateAttribution[]
  commissionRules CommissionRule[]
  commissions AffiliateCommission[] @relation("AffiliateCommissionAffiliate")
  sourceCommissions AffiliateCommission[] @relation("AffiliateCommissionSource")
  walletLedgers AffiliateWalletLedger[]
  payouts AffiliatePayout[]
  coupons AffiliateCoupon[]
  notifications AffiliateNotification[]
  auditLogs AffiliateAuditLog[]

  @@unique([shopId, referralCode])
  @@index([shopId])
  @@index([parentAffiliateId])
  @@index([status])
}

model AffiliateTreeClosure {
  id                    String   @id @default(cuid())
  shopId                String
  ancestorAffiliateId   String
  descendantAffiliateId String
  depth                 Int
  createdAt             DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  ancestor Affiliate @relation("AffiliateTreeAncestor", fields: [ancestorAffiliateId], references: [id], onDelete: Cascade)
  descendant Affiliate @relation("AffiliateTreeDescendant", fields: [descendantAffiliateId], references: [id], onDelete: Cascade)

  @@unique([ancestorAffiliateId, descendantAffiliateId])
  @@index([shopId, descendantAffiliateId, depth])
}

model AffiliateClick {
  id               String   @id @default(cuid())
  shopId           String
  affiliateId      String
  referralCode     String
  landingUrl       String
  productId        String?
  campaignId       String?
  sessionId        String
  visitorId        String
  ipHash           String?
  userAgent        String?
  device           String?
  referrer         String?
  convertedOrderId String?
  createdAt        DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
  convertedOrder Order? @relation(fields: [convertedOrderId], references: [id])

  @@index([shopId, affiliateId])
  @@index([sessionId])
  @@index([visitorId])
}

model AffiliateAttribution {
  id              String                   @id @default(cuid())
  shopId          String
  affiliateId     String
  sessionId       String
  visitorId       String
  attributionType AffiliateAttributionType
  referralCode    String
  expiresAt       DateTime
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([shopId, sessionId])
  @@index([visitorId])
  @@index([affiliateId])
}

model CommissionRule {
  id                 String          @id @default(cuid())
  shopId             String
  affiliateProgramId String
  scope              CommissionScope
  affiliateId        String?
  productId          String?
  categoryId         String?
  collectionId       String?
  campaignId         String?
  type               CommissionType
  percentageBps      Int?
  fixedCents         Int?
  priority           Int             @default(0)
  startsAt           DateTime?
  endsAt             DateTime?
  active             Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliateProgram AffiliateProgram @relation(fields: [affiliateProgramId], references: [id], onDelete: Cascade)
  affiliate Affiliate? @relation(fields: [affiliateId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
  commissions AffiliateCommission[]

  @@index([shopId, scope])
  @@index([affiliateProgramId])
}

model MultiLevelCommissionRule {
  id                 String         @id @default(cuid())
  shopId             String
  affiliateProgramId String
  levelDepth         Int
  type               CommissionType
  percentageBps      Int?
  fixedCents         Int?
  commissionBase     CommissionBase @default(direct_commission)
  maxPerOrderCents   Int?
  maxPerMonthCents   Int?
  active             Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliateProgram AffiliateProgram @relation(fields: [affiliateProgramId], references: [id], onDelete: Cascade)
  commissions AffiliateCommission[]

  @@unique([affiliateProgramId, levelDepth])
  @@index([shopId])
}

model AffiliateCommission {
  id                   String                    @id @default(cuid())
  shopId               String
  affiliateId          String
  orderId              String?
  orderItemId          String?
  sourceAffiliateId    String?
  type                 AffiliateCommissionType
  levelDepth           Int                       @default(0)
  status               AffiliateCommissionStatus @default(pending)
  amountCents          Int
  currency             String                    @default("USD")
  commissionBaseCents  Int
  ruleId               String?
  multiLevelRuleId     String?
  reason               String?
  batchId              String?
  idempotencyKey       String?                   @unique
  availableAt          DateTime?
  approvedAt           DateTime?
  paidAt               DateTime?
  reversedAt           DateTime?
  metadata             Json?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliate Affiliate @relation("AffiliateCommissionAffiliate", fields: [affiliateId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id])
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])
  sourceAffiliate Affiliate? @relation("AffiliateCommissionSource", fields: [sourceAffiliateId], references: [id])
  rule CommissionRule? @relation(fields: [ruleId], references: [id])
  multiLevelRule MultiLevelCommissionRule? @relation(fields: [multiLevelRuleId], references: [id])
  walletLedgers AffiliateWalletLedger[]

  @@index([shopId, affiliateId])
  @@index([orderId])
  @@index([status])
}

model AffiliateWalletLedger {
  id            String                    @id @default(cuid())
  shopId        String
  affiliateId   String
  commissionId  String?
  payoutId      String?
  type          AffiliateWalletLedgerType
  amountCents   Int
  currency      String                    @default("USD")
  balanceType   AffiliateWalletBalanceType
  note          String?
  createdAt     DateTime                  @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  commission AffiliateCommission? @relation(fields: [commissionId], references: [id])
  payout AffiliatePayout? @relation(fields: [payoutId], references: [id])

  @@index([shopId, affiliateId])
  @@index([commissionId])
  @@index([payoutId])
}

model AffiliatePayout {
  id                             String                @id @default(cuid())
  shopId                         String
  affiliateId                    String
  amountCents                    Int
  feeCents                       Int                   @default(0)
  netAmountCents                 Int
  currency                       String                @default("USD")
  method                         AffiliatePayoutMethod
  status                         AffiliatePayoutStatus @default(requested)
  requestedAt                    DateTime              @default(now())
  approvedAt                     DateTime?
  paidAt                         DateTime?
  rejectedAt                     DateTime?
  batchId                        String?
  adminNote                      String?
  affiliateNote                  String?
  payoutDetailsSnapshotEncrypted String?
  createdAt                      DateTime              @default(now())
  updatedAt                      DateTime              @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  walletLedgers AffiliateWalletLedger[]

  @@index([shopId, affiliateId])
  @@index([status])
}

model AffiliateRank {
  id                 String   @id @default(cuid())
  shopId             String
  name               String
  priority           Int
  commissionBonusBps Int?
  description        String?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliates Affiliate[]
  requirements AffiliateRankRequirement[]

  @@unique([shopId, name])
  @@index([shopId, priority])
}

model AffiliateRankRequirement {
  id        String                       @id @default(cuid())
  rankId    String
  type      AffiliateRankRequirementType
  value     Int
  createdAt DateTime                     @default(now())

  rank AffiliateRank @relation(fields: [rankId], references: [id], onDelete: Cascade)
}

model AffiliateBonusRule {
  id            String                  @id @default(cuid())
  shopId        String
  type          AffiliateBonusType
  amountCents   Int
  percentageBps Int?
  limitType     AffiliateBonusLimitType @default(none)
  limitValue    Int?
  active        Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, type])
}

model AffiliateCoupon {
  id            String                      @id @default(cuid())
  shopId        String
  affiliateId   String
  productId     String?
  code          String
  type          AffiliateCouponType
  discountType  AffiliateCouponDiscountType
  discountValue Int
  maxUses       Int?
  usedCount     Int                         @default(0)
  expiresAt     DateTime?
  status        String                      @default("active")
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@unique([shopId, code])
  @@index([shopId, affiliateId])
}

model MarketingAsset {
  id        String             @id @default(cuid())
  shopId    String
  title     String
  type      MarketingAssetType
  imageUrl  String?
  targetUrl String
  width     Int?
  height    Int?
  active    Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, type])
}

model AffiliateNotification {
  id          String    @id @default(cuid())
  shopId      String
  affiliateId String?
  type        String
  title       String
  message     String
  readAt      DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliate Affiliate? @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([shopId, affiliateId])
}

model AffiliateAuditLog {
  id          String   @id @default(cuid())
  shopId      String
  actorUserId String?
  affiliateId String?
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  ipHash      String?
  createdAt   DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  affiliate Affiliate? @relation(fields: [affiliateId], references: [id])

  @@index([shopId, entityType, entityId])
  @@index([affiliateId])
}

model DiscountCode {
  id              String       @id @default(cuid())
  shopId          String
  code            String
  type            DiscountType
  value           Int
  startsAt        DateTime?
  endsAt          DateTime?
  maxRedemptions  Int?
  redemptionCount Int          @default(0)
  active          Boolean      @default(true)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, code])
  @@index([shopId])
}

model DigitalUnlock {
  id          String    @id @default(cuid())
  shopId      String
  orderId     String
  orderItemId String
  customerId  String
  productId   String
  unlockType  String
  unlockCode  String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  redeemedAt  DateTime?

  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@index([shopId])
  @@index([customerId])
  @@index([unlockCode])
}

model CreatorPayout {
  id            String    @id @default(cuid())
  shopId        String
  orderId       String
  creatorUserId String
  amountCents   Int
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  paidAt        DateTime?

  shop  Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([creatorUserId])
}
