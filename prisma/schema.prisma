generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShopStatus {
  draft
  active
  suspended
}

enum DomainType {
  system_subdomain
  custom_domain
  root_domain
}

enum DomainStatus {
  pending
  active
  failed
}

