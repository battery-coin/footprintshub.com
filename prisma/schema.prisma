  processed
  failed
}

enum IdempotencyKeyStatus {
  processing
  completed
  failed
  expired
}

model Shop {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  subdomain    String?    @unique
  customDomain String?    @unique
  description  String?
  logoUrl      String?
  bannerUrl    String?
  ownerUserId  String?
  status       ShopStatus @default(draft)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  owner                           User?                            @relation("ShopOwner", fields: [ownerUserId], references: [id])
  domains                         ShopDomain[]
  brands                          Brand[]
  products                        Product[]
  productOptions                  ProductOption[]
  productReviews                  ProductReview[]
  categories                      Category[]
  collections                     Collection[]
  wishlists                       Wishlist[]
  compareLists                    CompareList[]
  carts                           Cart[]
  orders                          Order[]
  orderHistories                  OrderHistory[]
  discounts                       DiscountCode[]
  discountRules                   DiscountRule[]
  giftVouchers                    GiftVoucher[]
  storeCreditLedgers              StoreCreditLedger[]
  loyaltyPointLedgers             LoyaltyPointLedger[]
  returnRequests                  ReturnRequest[]
  downloadAssets                  DownloadAsset[]
  downloadEntitlements            DownloadEntitlement[]
  informationPages                InformationPage[]
  banners                         Banner[]
  geoZones                        GeoZone[]
  taxClasses                      TaxClass[]
  taxRates                        TaxRate[]
  shippingMethods                 ShippingMethod[]
  weightClasses                   WeightClass[]
  lengthClasses                   LengthClass[]
  marketRegions                   MarketRegion[]
  salesChannels                   SalesChannel[]
  paymentProviderConfigs          PaymentProviderConfig[]
  paymentSessions                 PaymentSession[]
  paymentCollections              PaymentCollection[]
  printfulOrders                  PrintfulOrder[]
  stockLocations                  StockLocation[]
  inventoryItems                  InventoryItem[]
  inventoryReservations           InventoryReservation[]
  fulfillmentProviders            FulfillmentProvider[]
  shippingProfiles                ShippingProfile[]
  shippingOptions                 ShippingOption[]
  fulfillments                    Fulfillment[]
  promotions                      Promotion[]
  commerceEvents                  CommerceEvent[]
  shopSettings                    ShopSetting[]
  adminRoles                      AdminRole[]
  adminUserRoles                  AdminUserRole[]
  inventoryLedgers                InventoryLedger[]
  adminAuditLogs                  AdminAuditLog[]
  webhookEvents                   WebhookEvent[]
  customers                       Customer[]
  customerGroups                  CustomerGroup[]
  digitalUnlocks                  DigitalUnlock[]
  creatorPayouts                  CreatorPayout[]
  affiliatePrograms               AffiliateProgram[]
  affiliatePlans                  AffiliatePlan[]
  affiliatePlanLevels             AffiliatePlanLevel[]
  affiliatePerformanceTiers       AffiliatePerformanceTier[]
  affiliateQualificationSnapshots AffiliateQualificationSnapshot[]
  lifetimeCustomerAttributions    LifetimeCustomerAttribution[]
  affiliates                      Affiliate[]
  affiliateTreeClosures           AffiliateTreeClosure[]
  affiliateClicks                 AffiliateClick[]
  affiliateAttributions           AffiliateAttribution[]
  commissionRules                 CommissionRule[]
  multiLevelCommissionRules       MultiLevelCommissionRule[]
  affiliateCommissions            AffiliateCommission[]
  affiliateWalletLedgers          AffiliateWalletLedger[]
  affiliatePayouts                AffiliatePayout[]
  affiliateRanks                  AffiliateRank[]
  affiliateBonusRules             AffiliateBonusRule[]
  affiliateCoupons                AffiliateCoupon[]
  marketingAssets                 MarketingAsset[]
  affiliateNotifications          AffiliateNotification[]
  affiliateAuditLogs              AffiliateAuditLog[]

  @@index([ownerUserId])
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  role             UserRole @default(customer)
  heroStudioUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ownedShops     Shop[]          @relation("ShopOwner")
  customers      Customer[]
  adminAuditLogs AdminAuditLog[]
  orderHistories OrderHistory[]
  adminUserRoles AdminUserRole[]

  @@index([role])
  @@index([heroStudioUserId])
}

model ShopDomain {
  id        String       @id @default(cuid())
  shopId    String
  hostname  String       @unique
  type      DomainType
  status    DomainStatus @default(pending)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Brand {
  id             String   @id @default(cuid())
  shopId         String
  name           String
  slug           String
  description    String?
  imageUrl       String?
  seoTitle       String?
  seoDescription String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([shopId, slug])
  @@index([shopId, status])
}

model Product {
  id                    String            @id @default(cuid())
  shopId                String
  brandId               String?
  taxClassId            String?
  title                 String
  slug                  String
  subtitle              String?
  description           String
  shortDescription      String?
  productType           ProductType
  franchise             Franchise
  status                ProductStatus     @default(draft)
  visibility            ProductVisibility @default(visible)
  priceCents            Int
  compareAtPriceCents   Int?
  currency              String            @default("USD")
  sku                   String?
  inventoryQuantity     Int               @default(0)
  trackInventory        Boolean           @default(true)
  allowBackorder        Boolean           @default(false)
  lowStockThreshold     Int?
  imageUrl              String?
  galleryUrls           String[]          @default([])
  seoTitle              String?
  seoDescription        String?
  metaKeywords          String[]          @default([])
  isFeatured            Boolean           @default(false)
  isLimitedEdition      Boolean           @default(false)
  preorderStatus        String?
  preorderReleaseAt     DateTime?
  requiresShipping      Boolean           @default(true)
  digitalUnlockIncluded Boolean           @default(false)
  tokenGated            Boolean           @default(false)
  tokenGateRule         Json?
  isRandomized          Boolean           @default(false)
  oddsDisclosureUrl     String?
  metadata              Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  shop               Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  brand              Brand?                @relation(fields: [brandId], references: [id])
  taxClass           TaxClass?             @relation(fields: [taxClassId], references: [id])
  variants           ProductVariant[]
  media              ProductMedia[]
  options            ProductOption[]
  reviews            ProductReview[]
  productCategories  ProductCategory[]
  productCollections ProductCollection[]
  salesChannels      ProductSalesChannel[]
  relatedProducts    RelatedProduct[]      @relation("ProductRelatedSource")
  relatedTo          RelatedProduct[]      @relation("ProductRelatedTarget")
  wishlistItems      WishlistItem[]
  compareItems       CompareItem[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  downloadAssets     DownloadAsset[]
  unlocks            DigitalUnlock[]
  affiliateClicks    AffiliateClick[]
  commissionRules    CommissionRule[]
  affiliateCoupons   AffiliateCoupon[]
  inventoryLedgers   InventoryLedger[]

  @@unique([shopId, slug])
  @@index([shopId])
  @@index([brandId])
  @@index([franchise])
  @@index([productType])
  @@index([status, visibility])
  @@index([taxClassId])
}

model ProductOption {
  id        String            @id @default(cuid())
  shopId    String
  productId String
  name      String
  type      ProductOptionType
  required  Boolean           @default(false)
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  shop    Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  ProductOptionValue[]

  @@index([shopId, productId])
  @@index([productId, sortOrder])
}

model ProductOptionValue {
  id              String   @id @default(cuid())
  optionId        String
  label           String
  skuSuffix       String?
  priceDeltaCents Int      @default(0)
  inventoryDelta  Int?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  option ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([optionId, sortOrder])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  title             String
  sku               String?
  priceCents        Int?
  inventoryQuantity Int      @default(0)
  trackInventory    Boolean  @default(true)
  allowBackorder    Boolean  @default(false)
  lowStockThreshold Int?
  attributes        Json?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product               Product                       @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems             CartItem[]
  orderItems            OrderItem[]
  wishlistItems         WishlistItem[]
  inventoryLedgers      InventoryLedger[]
  variantInventoryItems ProductVariantInventoryItem[]

  @@index([productId])
  @@index([sku])
}

model ProductMedia {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  mediaType String   @default("image")
  sortOrder Int      @default(0)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Category {
  id             String   @id @default(cuid())
  shopId         String
  parentId       String?
  name           String
  slug           String
  description    String?
  imageUrl       String?
  seoTitle       String?
  seoDescription String?
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop     Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  parent   Category?         @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[]        @relation("CategoryParent")
  products ProductCategory[]

  @@unique([shopId, slug])
  @@index([shopId, parentId])
}

model ProductCategory {
  productId  String
  categoryId String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId, sortOrder])
}

model Collection {
  id             String   @id @default(cuid())
  shopId         String
  name           String
  slug           String
  description    String?
  imageUrl       String?
  seoTitle       String?
  seoDescription String?
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop     Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products ProductCollection[]

  @@unique([shopId, slug])
  @@index([shopId, active])
}

model ProductCollection {
  productId    String
  collectionId String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId, sortOrder])
}

model RelatedProduct {
  id               String             @id @default(cuid())
  shopId           String
  sourceProductId  String
  relatedProductId String
  type             RelatedProductType @default(related)
  sortOrder        Int                @default(0)
  createdAt        DateTime           @default(now())

  sourceProduct  Product @relation("ProductRelatedSource", fields: [sourceProductId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("ProductRelatedTarget", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, relatedProductId, type])
  @@index([shopId, sourceProductId, type])
}

model Cart {
  id                    String     @id @default(cuid())
  shopId                String
  customerId            String?
  appliedDiscountCodeId String?
  sessionId             String
  currency              String     @default("USD")
  status                CartStatus @default(active)
  expiresAt             DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  shop                  Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer              Customer?              @relation(fields: [customerId], references: [id])
  discountCode          DiscountCode?          @relation(fields: [appliedDiscountCodeId], references: [id])
  items                 CartItem[]
  paymentSessions       PaymentSession[]
  inventoryReservations InventoryReservation[]

  @@index([shopId])
  @@index([sessionId])
  @@index([status, expiresAt])
}

model CartItem {
  id             String   @id @default(cuid())
  cartId         String
  productId      String
  variantId      String?
  quantity       Int
  unitPriceCents Int
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([cartId])
  @@index([productId])
}

model Order {
  id                      String            @id @default(cuid())
  shopId                  String
  customerId              String?
  cartId                  String?
  affiliateAttributionId  String?
  orderNumber             String            @unique
  status                  OrderStatus       @default(pending)
  paymentStatus           PaymentStatus     @default(unpaid)
  fulfillmentStatus       FulfillmentStatus @default(unfulfilled)
  subtotalCents           Int
  discountCents           Int               @default(0)
  taxCents                Int               @default(0)
  shippingCents           Int               @default(0)
  totalCents              Int
  currency                String            @default("USD")
  stripeCheckoutSessionId String?           @unique
  stripePaymentIntentId   String?
  customerEmail           String?
  shippingAddress         Json?
  billingAddress          Json?
  adminNotes              String?
  termsAcceptedAt         DateTime?
  metadata                Json?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  shop                         Shop                          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer                     Customer?                     @relation(fields: [customerId], references: [id])
  items                        OrderItem[]
  addresses                    OrderAddress[]
  payments                     Payment[]
  paymentSessions              PaymentSession[]
  paymentCollections           PaymentCollection[]
  refunds                      Refund[]
  printfulOrders               PrintfulOrder[]
  shipments                    Shipment[]
  fulfillments                 Fulfillment[]
  histories                    OrderHistory[]
  returnRequests               ReturnRequest[]
  storeCreditLedgers           StoreCreditLedger[]
  loyaltyPointLedgers          LoyaltyPointLedger[]
  downloadEntitlements         DownloadEntitlement[]
  unlocks                      DigitalUnlock[]
  payouts                      CreatorPayout[]
  affiliateClicks              AffiliateClick[]
  affiliateCommissions         AffiliateCommission[]
  lifetimeCustomerAttributions LifetimeCustomerAttribution[]
  inventoryLedgers             InventoryLedger[]
  inventoryReservations        InventoryReservation[]
  commerceEvents               CommerceEvent[]
  webhookEvents                WebhookEvent[]

  @@index([shopId])
  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String
  variantId      String?
  titleSnapshot  String
  skuSnapshot    String?
  quantity       Int
  unitPriceCents Int
  discountCents  Int     @default(0)
  taxCents       Int     @default(0)
  totalCents     Int
  metadata       Json?

  order                Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product              Product               @relation(fields: [productId], references: [id])
  variant              ProductVariant?       @relation(fields: [variantId], references: [id])
  unlocks              DigitalUnlock[]
  affiliateCommissions AffiliateCommission[]
  refunds              Refund[]
  refundItems          RefundItem[]
  returnRequests       ReturnRequest[]
  downloadEntitlements DownloadEntitlement[]
  shipmentItems        ShipmentItem[]
  inventoryLedgers     InventoryLedger[]
  fulfillmentItems     FulfillmentItem[]

  @@index([orderId])
  @@index([productId])
}

model OrderAddress {
  id         String           @id @default(cuid())
  orderId    String
  type       OrderAddressType
  name       String?
  company    String?
  line1      String
  line2      String?
  city       String
  region     String?
  postalCode String
  country    String
  phone      String?
  metadata   Json?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, type])
}

model OrderHistory {
  id                String             @id @default(cuid())
  shopId            String
  orderId           String
  actorUserId       String?
  status            OrderStatus?
  paymentStatus     PaymentStatus?
  fulfillmentStatus FulfillmentStatus?
  comment           String?
  customerVisible   Boolean            @default(false)
