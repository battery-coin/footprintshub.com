model Shop {
  id                           String           @id @default(cuid())
  name                         String
  slug                         String           @unique
  subdomain                    String?          @unique
  customDomain                 String?          @unique
  description                  String?
  logoUrl                      String?
  bannerUrl                    String?
  ownerUserId                  String?
  status                       ShopStatus       @default(draft)
  printfulEnabled              Boolean          @default(false)
  printfulStoreId              String?
  printfulMode                 ShopPrintfulMode @default(platform_account)
  printfulDefaultConfirmOrders Boolean          @default(false)
  createdAt                    DateTime         @default(now())
  updatedAt                    DateTime         @updatedAt

  owner                           User?                            @relation("ShopOwner", fields: [ownerUserId], references: [id])
  domains                         ShopDomain[]
  brands                          Brand[]
  products                        Product[]
  productOptions                  ProductOption[]
  productReviews                  ProductReview[]
  categories                      Category[]
  collections                     Collection[]
  wishlists                       Wishlist[]
  compareLists                    CompareList[]
  carts                           Cart[]
  orders                          Order[]
  orderHistories                  OrderHistory[]
  discounts                       DiscountCode[]
  discountRules                   DiscountRule[]
  giftVouchers                    GiftVoucher[]
  storeCreditLedgers              StoreCreditLedger[]
  loyaltyPointLedgers             LoyaltyPointLedger[]
  returnRequests                  ReturnRequest[]
  downloadAssets                  DownloadAsset[]
  downloadEntitlements            DownloadEntitlement[]
  informationPages                InformationPage[]
  banners                         Banner[]
  geoZones                        GeoZone[]
  taxClasses                      TaxClass[]
  taxRates                        TaxRate[]
  shippingMethods                 ShippingMethod[]
  tokenPaymentAssets              TokenPaymentAsset[]
  paymentPolicies                 PaymentPolicy[]
  productPaymentPolicies          ProductPaymentPolicy[]
  subscriptionPaymentPolicies     SubscriptionPaymentPolicy[]
  orderPaymentCompositions        OrderPaymentComposition[]
  tokenPaymentIntents             TokenPaymentIntent[]
  weightClasses                   WeightClass[]
  lengthClasses                   LengthClass[]
  marketRegions                   MarketRegion[]
  salesChannels                   SalesChannel[]
  paymentProviderConfigs          PaymentProviderConfig[]
  paymentSessions                 PaymentSession[]
  paymentCollections              PaymentCollection[]
  printfulOrders                  PrintfulOrder[]
  printfulOrderItems              PrintfulOrderItem[]
  printfulWebhookEvents           PrintfulWebhookEvent[]
  stockLocations                  StockLocation[]
  inventoryItems                  InventoryItem[]
  inventoryReservations           InventoryReservation[]
  fulfillmentProviders            FulfillmentProvider[]
  shippingProfiles                ShippingProfile[]
  shippingOptions                 ShippingOption[]
  fulfillments                    Fulfillment[]
  promotions                      Promotion[]
  commerceEvents                  CommerceEvent[]
  shopSettings                    ShopSetting[]
  adminRoles                      AdminRole[]
  adminUserRoles                  AdminUserRole[]
  inventoryLedgers                InventoryLedger[]
  adminAuditLogs                  AdminAuditLog[]
  webhookEvents                   WebhookEvent[]
  customers                       Customer[]
  customerGroups                  CustomerGroup[]
  digitalUnlocks                  DigitalUnlock[]
  creatorPayouts                  CreatorPayout[]
  affiliatePrograms               AffiliateProgram[]
  affiliatePlans                  AffiliatePlan[]
  affiliatePlanLevels             AffiliatePlanLevel[]
  binaryPlanConfigs               BinaryPlanConfig[]
  binaryLegVolumes                BinaryLegVolume[]
  matrixPlanConfigs               MatrixPlanConfig[]
  matrixPositions                 MatrixPosition[]
  unilevelPlanConfigs             UnilevelPlanConfig[]
  affiliatePerformanceTiers       AffiliatePerformanceTier[]
  affiliateQualificationSnapshots AffiliateQualificationSnapshot[]
  lifetimeCustomerAttributions    LifetimeCustomerAttribution[]
  affiliates                      Affiliate[]
  affiliateTreeClosures           AffiliateTreeClosure[]
  affiliateClicks                 AffiliateClick[]
  affiliateAttributions           AffiliateAttribution[]
  commissionRules                 CommissionRule[]
  multiLevelCommissionRules       MultiLevelCommissionRule[]
  affiliateCommissions            AffiliateCommission[]
  affiliateWalletLedgers          AffiliateWalletLedger[]
  affiliatePayouts                AffiliatePayout[]
  affiliateRanks                  AffiliateRank[]
  affiliateBonusRules             AffiliateBonusRule[]
  affiliateCoupons                AffiliateCoupon[]
  marketingAssets                 MarketingAsset[]
  affiliateNotifications          AffiliateNotification[]
  affiliateAuditLogs              AffiliateAuditLog[]
  discountSchedules               DiscountSchedule[]
  importJobs                      ImportJob[]
  userAppRoles                    UserAppRole[]
  adPlacements                    AdPlacement[]
  adProductConfigs                AdProductConfig[]
  adCampaigns                     AdCampaign[]
  adCreatives                     AdCreative[]
  adScheduleSlots                 AdScheduleSlot[]
  adMetrics                       AdMetric[]
  adClicks                        AdClick[]
  adImpressions                   AdImpression[]
  sponsoredPlacements             SponsoredPlacement[]
  adPolicyAcceptances             AdPolicyAcceptance[]
  adSubscriptions                 AdSubscription[]

  @@index([ownerUserId])
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  role             UserRole @default(customer)
  heroStudioUserId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ownedShops     Shop[]          @relation("ShopOwner")
  customers      Customer[]
  adminAuditLogs AdminAuditLog[]
  orderHistories OrderHistory[]
  adminUserRoles AdminUserRole[]
  appRoles       UserAppRole[]

  @@index([role])
  @@index([heroStudioUserId])
}

model ShopDomain {
  id        String       @id @default(cuid())
  shopId    String
  hostname  String       @unique
  type      DomainType
  status    DomainStatus @default(pending)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Brand {
  id             String   @id @default(cuid())
  shopId         String
  name           String
  slug           String
  description    String?
  imageUrl       String?
  seoTitle       String?
  seoDescription String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([shopId, slug])
  @@index([shopId, status])
}

model Product {
  id                          String                 @id @default(cuid())
  shopId                      String
  brandId                     String?
  taxClassId                  String?
  title                       String
  slug                        String
  subtitle                    String?
  description                 String
  shortDescription            String?
  productType                 ProductType
  paymentMode                 ProductPaymentMode     @default(one_time)
  franchise                   Franchise
  status                      ProductStatus          @default(draft)
  visibility                  ProductVisibility      @default(visible)
  priceCents                  Int
  compareAtPriceCents         Int?
  costCents                   Int?
  barcode                     String?
  currency                    String                 @default("USD")
  sku                         String?
  vendor                      String?
  tags                        String[]               @default([])
  inventoryQuantity           Int                    @default(0)
  trackInventory              Boolean                @default(true)
  allowBackorder              Boolean                @default(false)
  lowStockThreshold           Int?
  imageUrl                    String?
  galleryUrls                 String[]               @default([])
  seoTitle                    String?
  seoDescription              String?
  canonicalUrl                String?
  metaKeywords                String[]               @default([])
  isFeatured                  Boolean                @default(false)
  isLimitedEdition            Boolean                @default(false)
  preorderStatus              String?
  preorderReleaseAt           DateTime?
  requiresShipping            Boolean                @default(true)
  deliveryMode                ProductDeliveryMode    @default(shipped)
  requiresScheduling          Boolean                @default(false)
  requiresDownload            Boolean                @default(false)
  requiresWallet              Boolean                @default(false)
  subscriptionEligible        Boolean                @default(false)
  nftEligible                 Boolean                @default(false)
  accessDurationDays          Int?
  termsRequired               Boolean                @default(false)
  refundPolicyOverrideId      String?
  weightValue                 Decimal?
  weightUnit                  String?
  lengthValue                 Decimal?
  widthValue                  Decimal?
  heightValue                 Decimal?
  dimensionUnit               String?
  taxable                     Boolean                @default(true)
  fulfillmentType             ProductFulfillmentType @default(manual)
  printfulProductId           String?
  printfulSyncProductId       String?
  printfulTemplateId          String?
  printfulEnabled             Boolean                @default(false)
  printfulNeedsVariantMapping Boolean                @default(false)
  digitalUnlockIncluded       Boolean                @default(false)
  tokenGated                  Boolean                @default(false)
  tokenGateRule               Json?
  isRandomized                Boolean                @default(false)
  blindBoxEligible            Boolean                @default(false)
  boosterPackEligible         Boolean                @default(false)
  affiliateEligible           Boolean                @default(true)
  oddsDisclosureUrl           String?
  publishedAt                 DateTime?
  scheduledPublishAt          DateTime?
  metadata                    Json?
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt

  shop               Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  brand              Brand?                 @relation(fields: [brandId], references: [id])
  taxClass           TaxClass?              @relation(fields: [taxClassId], references: [id])
  variants           ProductVariant[]
  media              ProductMedia[]
  options            ProductOption[]
  reviews            ProductReview[]
  productCategories  ProductCategory[]
  productCollections ProductCollection[]
  salesChannels      ProductSalesChannel[]
  relatedProducts    RelatedProduct[]       @relation("ProductRelatedSource")
  relatedTo          RelatedProduct[]       @relation("ProductRelatedTarget")
  wishlistItems      WishlistItem[]
  compareItems       CompareItem[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  downloadAssets     DownloadAsset[]
  serviceProducts    ServiceProduct[]
  subscriptionPlans  SubscriptionPlan[]
  nftProducts        NFTProduct[]
  adProductConfig    AdProductConfig?
  adCampaigns        AdCampaign[]
  bundleItems        ProductBundleItem[]    @relation("BundleProduct")
  bundledIn          ProductBundleItem[]    @relation("ChildProduct")
  unlocks            DigitalUnlock[]
  affiliateClicks    AffiliateClick[]
